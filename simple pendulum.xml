<mujoco model="simple pendulum">
  <include file="scene.xml"/>
  <compiler angle="radian"/>
  <worldbody>
    <body name="pivot" pos="0 0 2">
      <geom type="sphere" size="0.1" rgba="1 0 0 1"/>
      <body name="string" pos="0 0 -1">
        <joint type="hinge" axis="0 1 0"/>
        <geom type="cylinder" size="0.05 0.1" rgba="1 1 0 1"/>
        <body name="bob" pos="0 0 -1">
          <geom type="sphere" size="0.7" rgba="0 0 1 1"/>
        </body>
      </body>
    </body>
  </worldbody>
</mujoco>